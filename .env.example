# App
APP_NAME="Titanium Rental Car"
APP_URL=http://localhost
APP_BASE=
# Landing pública na raiz (/) para visitantes. false = redireciona direto para /login
APP_LANDING=true

# LGPD — dados exibidos em /privacidade (preencha em produção)
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTROLLER_CNPJ=
PRIVACY_ADDRESS=
PRIVACY_DPO_EMAIL=
PRIVACY_DPO_PHONE=
SECURITY_CONTACT_EMAIL=
APP_ENV=development
APP_DEBUG=true
APP_DEFAULT_LANG=pt-BR
APP_PER_PAGE=15

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=titanium_rental_car
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_LIFETIME=480
SESSION_SECURE=false

# Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_PATH=public/assets/uploads
